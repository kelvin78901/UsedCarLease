# copy to .env (repo root) and fill in. Used by docker compose and launchd.
ALR_INPROCESS_SCHEDULER=1
ALR_ADAPTERS=leasehackr,marketcheck
ALR_USE_LTR=auto

# --- crawl cadence (TUNED FOR MARKETCHECK FREE TIER: 500 calls/month) ---
# Each crawl makes ceil(ALR_MC_MAX_ROWS/50) Marketcheck calls. With MAX_ROWS=50
# that's 1 call/crawl; at 180 min that's 8/day = ~240/month, safely under 500.
# Raise the interval (or MAX_ROWS) and you risk burning the free quota.
ALR_CRAWL_INTERVAL_MIN=180

# Marketcheck (used-car inventory) - free key at marketcheck.com/apis
ALR_MARKETCHECK_KEY=PUT_YOUR_KEY_HERE
ALR_MC_ZIP=20001                  # your area
ALR_MC_RADIUS=100                 # free tier caps at 100 miles
ALR_MC_MAX_ROWS=50                # 1 API call per crawl on the free tier
# ALR_MC_PARAMS=price_range=10000-40000   # optional extra v2 filters

# Leasehackr (lease transfers, no key, no quota - your daily driver)
ALR_LH_CATEGORY=c/private-transfers/12
ALR_LH_MAX_TOPICS=60
ALR_LH_DELAY=0.5
