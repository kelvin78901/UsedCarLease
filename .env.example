# copy to .env and adjust. All optional; sane defaults in alr/config.py.
ALR_DATA_DIR=./data
ALR_DB_PATH=./data/autoleaserank.duckdb
ALR_LTR_MODEL=./data/ltr_lambdamart.txt

# which adapters each crawl runs. "seed" = offline; live = real scraping.
# ALR_ADAPTERS=leasehackr,swapalease,leasetrader
ALR_ADAPTERS=seed

# ranking: auto (LTR if model exists, else rules) | rules | ltr
ALR_USE_LTR=auto

# in-process crawl scheduler (used by docker). 1=on
ALR_INPROCESS_SCHEDULER=0
ALR_CRAWL_INTERVAL_MIN=30

ALR_VPIC_BASE=https://vpic.nhtsa.dot.gov/api
ALR_VPIC_BATCH_SIZE=50    # VINs per DecodeVINValuesBatch call (vPIC cap is 50)
ALR_VPIC_CONCURRENCY=2    # concurrent vPIC batch calls
ALR_HTTP_TIMEOUT=20

# --- concurrency (P1): per-source in-flight caps + retry attempts ---
ALR_LH_CONCURRENCY=2     # Discourse 429s easily; keep low
ALR_LH_DELAY=0.5         # politeness sleep per Leasehackr request
ALR_LH_RETRIES=3
ALR_MC_CONCURRENCY=3      # keep low on the free tier
ALR_MC_DELAY=0           # per-request sleep; raise (e.g. 0.3) to throttle a big Free sweep past 429s
ALR_MC_RETRIES=3

# --- Marketcheck (structured used-car inventory API) ---
# free tier key at https://www.marketcheck.com/apis
ALR_MARKETCHECK_KEY=
ALR_MC_ZIP=20001
ALR_MC_RADIUS=100
ALR_MC_MAX_ROWS=100
ALR_MC_APR=0.075          # finance assumptions used to estimate a monthly from price
ALR_MC_TERM=72
# ALR_MC_PARAMS=make=Toyota&price_range=10000-30000   # any extra v2 search params
# Query sweep (P1) to exceed the 1500-row/query cap. Default = 1 slice (quota safe).
# Each (zip x make x band) slice costs >=1 call; a fully paginated slice costs
# ceil(min(num_found,1500)/50) calls. Scale these up only on a paid tier.
# ALR_MC_ZIPS=20001,10001,90001,60601,77001     # distinct metros (disjoint > concentric)
# ALR_MC_MAKES=Toyota,Honda,Ford
# ALR_MC_PRICE_BANDS=10000-25000,25000-40000,40000-70000
ALR_MC_PER_QUERY_CAP=1500

# --- Leasehackr ---
# Comma-separated Discourse category paths. Leave UNSET for private-transfers only
# (the only board with real lease takeovers). Explicit override example:
# ALR_LH_CATEGORY=c/private-transfers/12,c/marketplace/california/14
# AUTODISCOVER=1 also crawls regional "marketplace" boards, but those are broker
# ad threads (~0 real transfers, fail the deal-sheet gate) -> off by default.
ALR_LH_AUTODISCOVER=0
ALR_LH_MAX_TOPICS=60      # PER category (caps topic bodies fetched)
ALR_LH_MAX_PAGES=12       # PER category (only as many as MAX_TOPICS needs are fetched)
# politeness = ALR_LH_CONCURRENCY (in-flight cap) + ALR_LH_DELAY (per-request sleep)
